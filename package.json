{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "tristanbudd.com",
  "version": "1.0.0",
  "description": "Personal Portfolio & Professional Showcase | Built with Next.js 16, React 19, and Tailwind CSS 4",
  "author": "Tristan Budd <https://github.com/tristanbudd>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/tristanbudd/tristanbudd.com.git"
  },
  "bugs": {
    "url": "https://github.com/tristanbudd/tristanbudd.com/issues"
  },
  "homepage": "https://tristanbudd.com",
  "keywords": [
    "nextjs",
    "react",
    "portfolio",
    "tailwindcss",
    "typescript",
    "tristan-budd"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm prisma generate && next build",
    "start": "next start",
    "typecheck": "pnpm prisma generate && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^0.470.0",
    "mariadb": "^3.5.3",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "@hono/node-server": "^1.19.13",
      "js-yaml": "^4.2.0",
      "@babel/core": "^7.29.6"
    }
  }
}
